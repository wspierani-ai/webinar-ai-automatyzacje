# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_SECRET_TOKEN=your-webhook-secret-token

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-central2

# Cloud Tasks
CLOUD_TASKS_REMINDERS_QUEUE=reminders
CLOUD_TASKS_NUDGES_QUEUE=nudges
CLOUD_RUN_SERVICE_URL=https://your-service-url.run.app

# Stripe
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Admin
ADMIN_JWT_SECRET=your-admin-jwt-secret
ADMIN_EMAIL_WHITELIST=admin@example.com,admin2@example.com

# Google OAuth (for admin SSO + user calendar/tasks)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

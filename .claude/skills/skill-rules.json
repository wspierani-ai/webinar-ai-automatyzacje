{
    "version": "1.0",
    "description": "Skill activation triggers. Controls when skills automatically suggest or block actions.",
    "skills": {
        "tailwind-react-guidelines": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "React + TailwindCSS + shadcn/ui component patterns and best practices",
            "pathPatterns": [
                "src/components/**/*.tsx",
                "src/components/**/*.ts",
                "src/**/*.tsx",
                "src/pages/**/*.tsx",
                "src/hooks/**/*.ts"
            ],
            "promptTriggers": {
                "keywords": [
                    "tailwind",
                    "className",
                    "shadcn",
                    "radix",
                    "lazy loading",
                    "suspense",
                    "react query",
                    "react hook form",
                    "leniwe ladowanie",
                    "stan komponentu",
                    "klasy css",
                    "ciemny motyw",
                    "jasny motyw",
                    "zod",
                    "sonner"
                ],
                "intentPatterns": [
                    "(create|add|build|stworz|dodaj|zbuduj).*?(component|komponent)",
                    "(style|styluj|tailwind).*?(component|element)",
                    "(use|uzyj).*?(shadcn|radix)",
                    "(lazy|suspense).*?(load|loading)",
                    "(react|hook).*?(pattern|wzorzec)"
                ]
            }
        },
        "supabase-dev-guidelines": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Supabase patterns: Auth, Database, RLS, Edge Functions",
            "pathPatterns": [
                "supabase/**/*",
                "src/lib/supabase.ts",
                "src/hooks/useAuth.ts",
                "src/hooks/useProfile.ts",
                "src/components/Auth*.tsx"
            ],
            "promptTriggers": {
                "keywords": [
                    "supabase",
                    "baza danych",
                    "rls",
                    "row level security",
                    "autentykacja",
                    "oauth",
                    "google oauth",
                    "facebook oauth",
                    "edge function",
                    "migracja",
                    "security definer",
                    "realtime",
                    "zapytanie sql",
                    "schemat bazy",
                    "polityka rls",
                    "bezpieczenstwo bazy",
                    "service role",
                    "anon key",
                    "funkcja edge",
                    "deno",
                    "stripe webhook"
                ],
                "intentPatterns": [
                    "(create|add|stworz|dodaj).*?(table|tabela|migration|migracja)",
                    "(rls|policy|polityka).*?(add|create|update)",
                    "(edge function|funkcja edge).*?(create|deploy|stworz)",
                    "(supabase).*?(query|zapytanie|insert|update|delete)"
                ]
            }
        },
        "ux-ui-guidelines": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "UX/UI patterns: accessibility, animations, responsive design, design system",
            "pathPatterns": [
                "src/components/**/*.tsx",
                "src/pages/**/*.tsx"
            ],
            "promptTriggers": {
                "keywords": [
                    "accessibility",
                    "dostepnosc",
                    "wcag",
                    "aria",
                    "screen reader",
                    "czytnik ekranu",
                    "framer motion",
                    "view transition",
                    "prefers reduced motion",
                    "mobile-first",
                    "mobile first",
                    "container query",
                    "aria label",
                    "role aria",
                    "tab index",
                    "skeleton",
                    "empty state",
                    "error state",
                    "onboarding",
                    "paginacja",
                    "szkielet ladowania",
                    "pusty stan",
                    "nawigacja klawiatura",
                    "oklch",
                    "design system",
                    "system kolorow"
                ],
                "intentPatterns": [
                    "(accessibility|dostepnosc|wcag|aria)",
                    "(animate|animuj|animation|animacja)",
                    "(responsive|mobile|tablet|desktop)",
                    "(modal|dialog|form|formularz).*?(ux|pattern|wzorzec)",
                    "(loading|skeleton|empty|error).*?(state|stan)",
                    "(focus|keyboard|klawiatura).*?(navigation|nawigacja)"
                ]
            }
        },
        "sentry-integration": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Sentry error tracking i performance monitoring dla React + Supabase Edge Functions",
            "pathPatterns": [
                "src/lib/sentry.ts",
                "src/lib/logger.ts",
                "supabase/functions/**/*.ts",
                "supabase/functions/_shared/sentry.ts"
            ],
            "promptTriggers": {
                "keywords": [
                    "sentry",
                    "error tracking",
                    "captureException",
                    "captureMessage",
                    "sledzenie bledow",
                    "monitorowanie bledow",
                    "raportowanie bledow",
                    "error boundary",
                    "granica bledow"
                ],
                "intentPatterns": [
                    "(add|dodaj|integrate|zintegruj).*?(sentry|error.*?tracking)",
                    "(error|blad|exception|wyjatek).*?(capture|przechwyc|log|zaloguj)",
                    "(monitoring|monitorowanie).*?(setup|konfiguracja)",
                    "(performance|wydajnosc).*?(track|sledz)"
                ]
            }
        },
        "code-review": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Code review dla PR i implementacji — raport z klasyfikacją problemów",
            "promptTriggers": {
                "keywords": [
                    "code review",
                    "review PR",
                    "pull request review",
                    "przeglad kodu",
                    "ocena implementacji",
                    "review zmian",
                    "sprawdz kod",
                    "audyt kodu",
                    "weryfikacja kodu"
                ],
                "intentPatterns": [
                    "(review|przegladnij|sprawdz|ocen).*?(code|kod|PR|pull request|implementacj)",
                    "(code|kod).*?(review|przeglad|audyt|weryfikacj)"
                ]
            }
        }
    },
    "notes": {
        "enforcement_types": {
            "suggest": "Skill suggestion appears but doesn't block execution",
            "block": "Requires skill to be used before proceeding (guardrail)",
            "warn": "Shows warning but allows proceeding"
        },
        "priority_levels": {
            "critical": "Highest - Always trigger when matched",
            "high": "Important - Trigger for most matches",
            "medium": "Moderate - Trigger for clear matches",
            "low": "Optional - Trigger only for explicit matches"
        },
        "project_structure": {
            "frontend": "src/**/*.tsx, src/**/*.ts",
            "components": "src/components/**/*",
            "hooks": "src/hooks/**/*",
            "lib": "src/lib/**/*",
            "supabase": "supabase/**/*"
        }
    }
}
